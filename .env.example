# MariaDB (active by default)
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=devdb
DB_USERNAME=root
DB_PASSWORD=mariadb

# PostgreSQL (uncomment to use instead of MariaDB)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=devdb
# DB_USERNAME=postgres
# DB_PASSWORD=postgres

# Mail (Mailpit - catches all emails locally)
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=dev@example.com
MAIL_FROM_NAME="Dev Container"
