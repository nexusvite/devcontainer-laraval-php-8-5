{
	"id": "mailpit",
	"version": "0.0.1",
	"name": "Mailpit",
	"description": "Email testing tool - catches all outgoing emails with a web UI",
	"options": {
		"smtpPort": {
			"type": "string",
			"default": "1025",
			"description": "SMTP port for sending emails"
		},
		"uiPort": {
			"type": "string",
			"default": "8025",
			"description": "Web UI port for viewing emails"
		}
	},
	"entrypoint": "/usr/local/bin/mailpit-entrypoint",
	"customizations": {
		"coder": {
			"apps": [
				{
					"slug": "mailpit",
					"displayName": "Mailpit",
					"url": "http://localhost:${localEnv:FEATURE_MAILPIT_OPTION_UIPORT:8025}",
					"icon": "/icon/mailpit.svg",
					"order": 7,
					"healthcheck": {
						"url": "http://localhost:${localEnv:FEATURE_MAILPIT_OPTION_UIPORT:8025}",
						"interval": 5,
						"threshold": 2
					}
				}
			]
		}
	}
}
